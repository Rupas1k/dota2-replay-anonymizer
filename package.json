{
  "name": "d2-replay-anonymizer",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "Artem Rupasov <artemrupasov125@gmail.com>",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run build:wasm && vite build",
    "build:pages": "npm run build:wasm && vite build --mode pages",
    "build:wasm": "wasm-pack build crates/wasm --target web --out-dir ../../src/wasm-pkg --release",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.1.5"
  }
}
